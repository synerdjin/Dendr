# Dendr Docker Compose environment variables.
# Copy this to .env and fill in your values.

# Path to your Obsidian vault (required)
VAULT_PATH=C:\Users\genem\ObsidianVault

# Local data directory (models, database, queue). Uses Docker volume if unset.
# DENDR_DATA=C:\Users\genem\AppData\Local\Dendr

# HuggingFace token — optional. All current models are ungated, so this is only
# needed if you add a gated model to dendr-models.yaml.
# Get yours at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# Search server port (default: 7777)
# SEARCH_PORT=7777
